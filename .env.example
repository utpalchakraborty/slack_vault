# Local app behavior
SLACK_VAULT_ENV=local
SLACK_VAULT_OBSIDIAN_PATH=/Users/utpalrohan/code/slack_obsidian
SLACK_VAULT_OBSIDIAN_CLI_VAULT=slack_obsidian
SLACK_VAULT_ARCHIVE_PROVIDER=local
SLACK_VAULT_ARCHIVE_PATH=.data/archive
SLACK_VAULT_LOG_PATH=.data/logs/slack-vault.log
SLACK_VAULT_LOG_LEVEL=INFO
SLACK_VAULT_LOG_BACKUP_COUNT=14
SLACK_VAULT_OPERATIONAL_DB_PATH=.data/slack-vault.sqlite3
SLACK_VAULT_AUTOMATIC_INGEST_DELAY_SECONDS=75

# Slack app credentials and Phase 6 routing
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_APP_TOKEN=xapp-your-token
SLACK_VAULT_APP_ID=A0123456789
SLACK_APP_CONFIG_TOKEN=xoxe-your-config-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_VAULT_SLACK_EVENT_DELIVERY_MODE=socket
SLACK_VAULT_ENTERPRISE_ID=E0123456789
SLACK_VAULT_TEAM_ID=T0123456789
SLACK_VAULT_INGESTION_CHANNEL_ID=C0123456789
SLACK_VAULT_INGESTION_CHANNEL_NAME=slack-vault-dev-ingest
SLACK_VAULT_INGESTION_CHANNEL_IS_PRIVATE=false
SLACK_VAULT_ALLOW_EXTERNAL_SHARED_CHANNELS=false

# Slack ingestion behavior
SLACK_VAULT_SLACK_INGEST_ENHANCE=false
SLACK_VAULT_SLACK_INGEST_SYNTHESIZE=true
SLACK_VAULT_SLACK_INGEST_GIT_COMMIT=true
SLACK_VAULT_SLACK_INGEST_GIT_PUSH=true

# AI provider
SLACK_VAULT_AI_PROVIDER=anthropic
SLACK_VAULT_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
SLACK_VAULT_AI_MAX_INPUT_TOKENS=200000
SLACK_VAULT_AI_MAX_OUTPUT_TOKENS=64000
SLACK_VAULT_AI_RETRY_MAX_ATTEMPTS=3
SLACK_VAULT_AI_RETRY_INITIAL_DELAY_SECONDS=60
SLACK_VAULT_AI_RETRY_MAX_DELAY_SECONDS=300
SLACK_VAULT_AI_RETRY_BACKOFF_MULTIPLIER=2
ANTHROPIC_API_KEY=sk-ant-your-key

# Live test gates
SLACK_VAULT_RUN_LIVE_AI_TESTS=0
SLACK_VAULT_RUN_LIVE_SLACK_TESTS=0
